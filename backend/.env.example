APP_MODE=local
SETTINGS_ENV=local
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/logbook
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_KEY\n-----END PUBLIC KEY-----"
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----"
JWT_ALGORITHM=RS256
JWT_ISSUER=logbook
JWT_AUDIENCE=logbook
FRONTEND_ASSERTION_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_KEY\n-----END PUBLIC KEY-----"
FRONTEND_ASSERTION_JWKS_URL=
FRONTEND_ASSERTION_ISSUER=logbook-frontend
ADMIN_ALLOWED_EMAILS=admin@example.com
UPLOAD_ROOT=uploads
ASSET_BASE_URL=http://localhost:8000/uploads
UPLOAD_IMAGE_MAX_BYTES=5242880

# テスト用（backend/.env.test）
APP_MODE=local
DATABASE_URL=sqlite+pysqlite:///./test.db
JWT_PUBLIC_KEY=dummy
JWT_ALGORITHM=RS256
ADMIN_ALLOWED_EMAILS=test@example.com
UPLOAD_ROOT=uploads
